# =========================================================================
# SYSTEM CONFIGURATION
# =========================================================================
PORT=3000
NODE_ENV=production

# APP_URL: Alamat URL deployment Anda di Northflank (contoh: https://samara-stay.code.northflank.com)
# Gunakan URL ini sebagai domain utama untuk konfigurasi Webhook di Dashboard Midtrans Anda.
APP_URL="YOUR_NORTHFLANK_APP_URL_HERE"


# =========================================================================
# GOOGLE GEMINI AI
# =========================================================================
# GEMINI_API_KEY: Diperlukan untuk fitur asisten AI di dalam aplikasi.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"


# =========================================================================
# SUPABASE CONFIGURATION (PERSISTENCE & REALTIME)
# =========================================================================
# Pastikan Supabase URL & Anon Key ini sesuai dengan project Supabase aktif Anda.
VITE_SUPABASE_URL="YOUR_SUPABASE_URL_HERE"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY_HERE"

# Alias opsional jika runtime server memerlukan nama variabel tanpa prefix VITE_
SUPABASE_URL="YOUR_SUPABASE_URL_HERE"
SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY_HERE"


# =========================================================================
# MIDTRANS PAYMENT GATEWAY
# =========================================================================
# Kunci Client Key untuk integrasi sisi frontend (Client-side Snap JS)
VITE_MIDTRANS_CLIENT_KEY="YOUR_MIDTRANS_CLIENT_KEY_HERE"
MIDTRANS_CLIENT_KEY="YOUR_MIDTRANS_CLIENT_KEY_HERE"

# Kunci Server Key (RAHASIA) - Jangan pernah diekspos ke client!
MIDTRANS_SERVER_KEY="YOUR_MIDTRANS_SERVER_KEY_HERE"


# =========================================================================
# MAILERSEND EMAIL NOTIFICATION
# =========================================================================
# Kunci API MailerSend untuk mengirimkan email konfirmasi & invoice otomatis
MAILERSEND_API_KEY="YOUR_MAILERSEND_API_KEY_HERE"

# Email Pengirim yang telah divalidasi/diverifikasi di dashboard MailerSend Anda
MAILERSEND_FROM_EMAIL="info@trial-3yxj5ljp10zg6o2r.mlsender.net"

# Nama Pengirim email yang akan tampil di inbox pelanggan
MAILERSEND_FROM_NAME="Samara Stay"
