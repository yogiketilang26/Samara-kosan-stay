# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="YOUR_APP_URL_HERE"

# SUPABASE: Connection properties for direct Supabase PostgreSQL tables
# Define these in your Secrets panel inside Google AI Studio to sync with your actual Supabase project.
VITE_SUPABASE_URL="YOUR_SUPABASE_URL_HERE"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY_HERE"

# MIDTRANS: Payment gateway keys for real online transactions (Sandbox or Production)
VITE_MIDTRANS_CLIENT_KEY="YOUR_MIDTRANS_CLIENT_KEY_HERE"
MIDTRANS_SERVER_KEY="YOUR_MIDTRANS_SERVER_KEY_HERE"

# MAILERSEND: API key for MailerSend premium email notifications
MAILERSEND_API_KEY="YOUR_MAILERSEND_API_KEY_HERE"
